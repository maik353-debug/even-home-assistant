{
  "name": "even-hub",
  "version": "1.0.0",
  "description": "Control your smart home in your G2",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit",
    "qr": "evenhub qr --port 3000",
    "sim": "evenhub-simulator http://127.0.0.1:3000",
    "init:app": "evenhub init --output app.json",
    "pack": "npm run build && evenhub pack app.json dist --output app.ehpk"
  },
  "keywords": [],
  "author": "ithurtswhenip4473",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.7"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.5",
    "@evenrealities/evenhub-simulator": "^0.1.2",
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
